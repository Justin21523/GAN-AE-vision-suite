!tests/fixtures/**

# Dataset (keep only placeholder/README)
/data/
!data/.gitkeep
!data/README.md

# --- FastAPI / Misc ---
# compiled static or temporary files
*.sqlite3
instance/

# --- Node / React (gan-ui) ---
gan-ui/node_modules/
gan-ui/.vite/
gan-ui/.cache/
gan-ui/dist/
gan-ui/.env*
!gan-ui/.env.example          # provide example if you want

# lockfiles should be tracked for reproducibility
# (so DO NOT ignore package-lock.json / pnpm-lock.yaml / yarn.lock)
# gan-ui/package-lock.json

# --- Images / temp ---
tmp/
*.tmp
